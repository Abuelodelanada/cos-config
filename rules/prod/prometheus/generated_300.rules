groups:
- name: GeneratedGroup300
  rules:
  - alert: HostHighCpuLoad30000
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g30000"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g30000 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g30000 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure30001
    expr: node_memory_MemAvailable_bytes{group="g30001"} / node_memory_MemTotal_bytes{group="g30001"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g30001 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g30001 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill30002
    expr: predict_linear(node_filesystem_free_bytes{group="g30002"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g30002 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g30002 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors30003
    expr: rate(node_network_receive_errs_total{group="g30003"}[2m]) + rate(node_network_transmit_errs_total{group="g30003"}[2m]) > 30003
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g30003 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g30003 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate30004
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g30004"}[2m])) / (1024*1024) > 300040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g30004 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g30004 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage30005
    expr: (1 - (node_memory_SwapFree_bytes{group="g30005"} / node_memory_SwapTotal_bytes{group="g30005"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g30005 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g30005 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching30006
    expr: rate(node_context_switches_total{group="g30006"}[5m]) > 30006000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g30006 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g30006 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew30007
    expr: abs(node_timex_offset_seconds{group="g30007"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g30007 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g30007 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills30008
    expr: increase(node_vmstat_oom_kill{group="g30008"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g30008 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g30008 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion30009
    expr: node_filefd_allocated{group="g30009"} / node_filefd_maximum{group="g30009"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g30009 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g30009 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
