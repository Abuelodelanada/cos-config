groups:
- name: GeneratedGroup194
  rules:
  - alert: HostHighCpuLoad19400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g19400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g19400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g19400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure19401
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g19401"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g19401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g19401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g19401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill19402
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g19402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g19402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g19402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors19403
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g19403"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g19403"}[2m]) > 19403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g19403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g19403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate19404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g19404"}[2m])) / (1024*1024) > 194040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g19404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g19404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage19405
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g19405"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g19405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g19405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g19405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching19406
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g19406"}[5m]) > 19406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g19406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g19406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew19407
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g19407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g19407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g19407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills19408
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g19408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g19408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g19408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion19409
    expr: node_filefd_allocated{%%juju_topology%%,group="g19409"} / node_filefd_maximum{%%juju_topology%%,group="g19409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g19409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g19409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
