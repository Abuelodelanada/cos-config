groups:
- name: GeneratedGroup271
  rules:
  - alert: HostHighCpuLoad27100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g27100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g27100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g27100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure27101
    expr: node_memory_MemAvailable_bytes{group="g27101"} / node_memory_MemTotal_bytes{group="g27101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g27101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g27101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill27102
    expr: predict_linear(node_filesystem_free_bytes{group="g27102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g27102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g27102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors27103
    expr: rate(node_network_receive_errs_total{group="g27103"}[2m]) + rate(node_network_transmit_errs_total{group="g27103"}[2m]) > 27103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g27103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g27103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate27104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g27104"}[2m])) / (1024*1024) > 271040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g27104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g27104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage27105
    expr: (1 - (node_memory_SwapFree_bytes{group="g27105"} / node_memory_SwapTotal_bytes{group="g27105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g27105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g27105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching27106
    expr: rate(node_context_switches_total{group="g27106"}[5m]) > 27106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g27106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g27106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew27107
    expr: abs(node_timex_offset_seconds{group="g27107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g27107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g27107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills27108
    expr: increase(node_vmstat_oom_kill{group="g27108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g27108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g27108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion27109
    expr: node_filefd_allocated{group="g27109"} / node_filefd_maximum{group="g27109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g27109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g27109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
