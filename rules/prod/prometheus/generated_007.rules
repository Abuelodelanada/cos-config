groups:
- name: GeneratedGroup7
  rules:
  - alert: HostHighCpuLoad700
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g700"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g700 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g700 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure701
    expr: node_memory_MemAvailable_bytes{group="g701"} / node_memory_MemTotal_bytes{group="g701"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g701 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g701 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill702
    expr: predict_linear(node_filesystem_free_bytes{group="g702"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g702 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g702 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors703
    expr: rate(node_network_receive_errs_total{group="g703"}[2m]) + rate(node_network_transmit_errs_total{group="g703"}[2m]) > 703
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g703 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g703 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate704
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g704"}[2m])) / (1024*1024) > 7040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g704 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g704 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage705
    expr: (1 - (node_memory_SwapFree_bytes{group="g705"} / node_memory_SwapTotal_bytes{group="g705"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g705 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g705 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching706
    expr: rate(node_context_switches_total{group="g706"}[5m]) > 706000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g706 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g706 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew707
    expr: abs(node_timex_offset_seconds{group="g707"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g707 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g707 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills708
    expr: increase(node_vmstat_oom_kill{group="g708"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g708 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g708 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion709
    expr: node_filefd_allocated{group="g709"} / node_filefd_maximum{group="g709"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g709 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g709 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
