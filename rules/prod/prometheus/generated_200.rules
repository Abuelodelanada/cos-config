groups:
- name: GeneratedGroup200
  rules:
  - alert: HostHighCpuLoad20000
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g20000"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g20000 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g20000 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure20001
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g20001"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g20001"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g20001 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g20001 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill20002
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g20002"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g20002 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g20002 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors20003
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g20003"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g20003"}[2m]) > 20003
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g20003 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g20003 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate20004
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g20004"}[2m])) / (1024*1024) > 200040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g20004 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g20004 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage20005
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g20005"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g20005"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g20005 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g20005 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching20006
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g20006"}[5m]) > 20006000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g20006 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g20006 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew20007
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g20007"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g20007 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g20007 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills20008
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g20008"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g20008 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g20008 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion20009
    expr: node_filefd_allocated{%%juju_topology%%,group="g20009"} / node_filefd_maximum{%%juju_topology%%,group="g20009"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g20009 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g20009 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
