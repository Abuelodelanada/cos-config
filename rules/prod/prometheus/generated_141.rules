groups:
- name: GeneratedGroup141
  rules:
  - alert: HostHighCpuLoad14100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g14100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g14100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g14100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure14101
    expr: node_memory_MemAvailable_bytes{group="g14101"} / node_memory_MemTotal_bytes{group="g14101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g14101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g14101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill14102
    expr: predict_linear(node_filesystem_free_bytes{group="g14102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g14102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g14102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors14103
    expr: rate(node_network_receive_errs_total{group="g14103"}[2m]) + rate(node_network_transmit_errs_total{group="g14103"}[2m]) > 14103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g14103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g14103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate14104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g14104"}[2m])) / (1024*1024) > 141040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g14104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g14104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage14105
    expr: (1 - (node_memory_SwapFree_bytes{group="g14105"} / node_memory_SwapTotal_bytes{group="g14105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g14105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g14105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching14106
    expr: rate(node_context_switches_total{group="g14106"}[5m]) > 14106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g14106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g14106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew14107
    expr: abs(node_timex_offset_seconds{group="g14107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g14107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g14107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills14108
    expr: increase(node_vmstat_oom_kill{group="g14108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g14108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g14108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion14109
    expr: node_filefd_allocated{group="g14109"} / node_filefd_maximum{group="g14109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g14109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g14109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
