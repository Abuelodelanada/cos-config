groups:
- name: GeneratedGroup151
  rules:
  - alert: HostHighCpuLoad15100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g15100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g15100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g15100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure15101
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g15101"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g15101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g15101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g15101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill15102
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g15102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g15102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g15102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors15103
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g15103"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g15103"}[2m]) > 15103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g15103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g15103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate15104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g15104"}[2m])) / (1024*1024) > 151040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g15104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g15104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage15105
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g15105"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g15105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g15105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g15105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching15106
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g15106"}[5m]) > 15106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g15106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g15106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew15107
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g15107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g15107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g15107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills15108
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g15108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g15108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g15108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion15109
    expr: node_filefd_allocated{%%juju_topology%%,group="g15109"} / node_filefd_maximum{%%juju_topology%%,group="g15109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g15109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g15109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
