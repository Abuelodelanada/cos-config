groups:
- name: GeneratedGroup168
  rules:
  - alert: HostHighCpuLoad16800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g16800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g16800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g16800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure16801
    expr: node_memory_MemAvailable_bytes{group="g16801"} / node_memory_MemTotal_bytes{group="g16801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g16801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g16801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill16802
    expr: predict_linear(node_filesystem_free_bytes{group="g16802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g16802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g16802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors16803
    expr: rate(node_network_receive_errs_total{group="g16803"}[2m]) + rate(node_network_transmit_errs_total{group="g16803"}[2m]) > 16803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g16803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g16803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate16804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g16804"}[2m])) / (1024*1024) > 168040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g16804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g16804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage16805
    expr: (1 - (node_memory_SwapFree_bytes{group="g16805"} / node_memory_SwapTotal_bytes{group="g16805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g16805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g16805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching16806
    expr: rate(node_context_switches_total{group="g16806"}[5m]) > 16806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g16806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g16806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew16807
    expr: abs(node_timex_offset_seconds{group="g16807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g16807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g16807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills16808
    expr: increase(node_vmstat_oom_kill{group="g16808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g16808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g16808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion16809
    expr: node_filefd_allocated{group="g16809"} / node_filefd_maximum{group="g16809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g16809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g16809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
