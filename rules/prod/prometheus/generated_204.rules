groups:
- name: GeneratedGroup204
  rules:
  - alert: HostHighCpuLoad20400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g20400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g20400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g20400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure20401
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g20401"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g20401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g20401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g20401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill20402
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g20402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g20402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g20402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors20403
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g20403"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g20403"}[2m]) > 20403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g20403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g20403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate20404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g20404"}[2m])) / (1024*1024) > 204040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g20404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g20404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage20405
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g20405"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g20405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g20405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g20405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching20406
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g20406"}[5m]) > 20406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g20406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g20406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew20407
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g20407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g20407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g20407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills20408
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g20408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g20408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g20408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion20409
    expr: node_filefd_allocated{%%juju_topology%%,group="g20409"} / node_filefd_maximum{%%juju_topology%%,group="g20409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g20409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g20409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
