groups:
- name: GeneratedGroup269
  rules:
  - alert: HostHighCpuLoad26900
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g26900"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g26900 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g26900 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure26901
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g26901"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g26901"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g26901 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g26901 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill26902
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g26902"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g26902 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g26902 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors26903
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g26903"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g26903"}[2m]) > 26903
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g26903 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g26903 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate26904
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g26904"}[2m])) / (1024*1024) > 269040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g26904 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g26904 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage26905
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g26905"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g26905"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g26905 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g26905 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching26906
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g26906"}[5m]) > 26906000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g26906 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g26906 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew26907
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g26907"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g26907 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g26907 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills26908
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g26908"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g26908 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g26908 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion26909
    expr: node_filefd_allocated{%%juju_topology%%,group="g26909"} / node_filefd_maximum{%%juju_topology%%,group="g26909"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g26909 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g26909 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
