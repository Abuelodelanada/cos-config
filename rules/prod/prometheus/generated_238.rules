groups:
- name: GeneratedGroup238
  rules:
  - alert: HostHighCpuLoad23800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g23800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g23800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g23800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure23801
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g23801"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g23801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g23801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g23801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill23802
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g23802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g23802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g23802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors23803
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g23803"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g23803"}[2m]) > 23803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g23803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g23803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate23804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g23804"}[2m])) / (1024*1024) > 238040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g23804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g23804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage23805
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g23805"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g23805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g23805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g23805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching23806
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g23806"}[5m]) > 23806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g23806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g23806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew23807
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g23807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g23807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g23807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills23808
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g23808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g23808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g23808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion23809
    expr: node_filefd_allocated{%%juju_topology%%,group="g23809"} / node_filefd_maximum{%%juju_topology%%,group="g23809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g23809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g23809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
