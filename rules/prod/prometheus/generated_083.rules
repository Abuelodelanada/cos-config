groups:
- name: GeneratedGroup83
  rules:
  - alert: HostHighCpuLoad8300
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g8300"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g8300 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g8300 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure8301
    expr: node_memory_MemAvailable_bytes{group="g8301"} / node_memory_MemTotal_bytes{group="g8301"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g8301 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g8301 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill8302
    expr: predict_linear(node_filesystem_free_bytes{group="g8302"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g8302 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g8302 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors8303
    expr: rate(node_network_receive_errs_total{group="g8303"}[2m]) + rate(node_network_transmit_errs_total{group="g8303"}[2m]) > 8303
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g8303 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g8303 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate8304
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g8304"}[2m])) / (1024*1024) > 83040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g8304 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g8304 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage8305
    expr: (1 - (node_memory_SwapFree_bytes{group="g8305"} / node_memory_SwapTotal_bytes{group="g8305"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g8305 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g8305 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching8306
    expr: rate(node_context_switches_total{group="g8306"}[5m]) > 8306000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g8306 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g8306 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew8307
    expr: abs(node_timex_offset_seconds{group="g8307"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g8307 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g8307 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills8308
    expr: increase(node_vmstat_oom_kill{group="g8308"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g8308 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g8308 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion8309
    expr: node_filefd_allocated{group="g8309"} / node_filefd_maximum{group="g8309"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g8309 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g8309 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
