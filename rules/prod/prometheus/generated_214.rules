groups:
- name: GeneratedGroup214
  rules:
  - alert: HostHighCpuLoad21400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g21400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g21400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g21400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure21401
    expr: node_memory_MemAvailable_bytes{group="g21401"} / node_memory_MemTotal_bytes{group="g21401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g21401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g21401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill21402
    expr: predict_linear(node_filesystem_free_bytes{group="g21402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g21402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g21402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors21403
    expr: rate(node_network_receive_errs_total{group="g21403"}[2m]) + rate(node_network_transmit_errs_total{group="g21403"}[2m]) > 21403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g21403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g21403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate21404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g21404"}[2m])) / (1024*1024) > 214040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g21404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g21404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage21405
    expr: (1 - (node_memory_SwapFree_bytes{group="g21405"} / node_memory_SwapTotal_bytes{group="g21405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g21405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g21405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching21406
    expr: rate(node_context_switches_total{group="g21406"}[5m]) > 21406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g21406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g21406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew21407
    expr: abs(node_timex_offset_seconds{group="g21407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g21407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g21407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills21408
    expr: increase(node_vmstat_oom_kill{group="g21408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g21408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g21408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion21409
    expr: node_filefd_allocated{group="g21409"} / node_filefd_maximum{group="g21409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g21409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g21409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
