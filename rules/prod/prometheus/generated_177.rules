groups:
- name: GeneratedGroup177
  rules:
  - alert: HostHighCpuLoad17700
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g17700"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g17700 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g17700 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure17701
    expr: node_memory_MemAvailable_bytes{group="g17701"} / node_memory_MemTotal_bytes{group="g17701"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g17701 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g17701 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill17702
    expr: predict_linear(node_filesystem_free_bytes{group="g17702"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g17702 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g17702 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors17703
    expr: rate(node_network_receive_errs_total{group="g17703"}[2m]) + rate(node_network_transmit_errs_total{group="g17703"}[2m]) > 17703
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g17703 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g17703 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate17704
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g17704"}[2m])) / (1024*1024) > 177040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g17704 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g17704 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage17705
    expr: (1 - (node_memory_SwapFree_bytes{group="g17705"} / node_memory_SwapTotal_bytes{group="g17705"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g17705 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g17705 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching17706
    expr: rate(node_context_switches_total{group="g17706"}[5m]) > 17706000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g17706 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g17706 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew17707
    expr: abs(node_timex_offset_seconds{group="g17707"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g17707 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g17707 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills17708
    expr: increase(node_vmstat_oom_kill{group="g17708"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g17708 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g17708 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion17709
    expr: node_filefd_allocated{group="g17709"} / node_filefd_maximum{group="g17709"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g17709 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g17709 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
