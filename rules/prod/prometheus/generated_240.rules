groups:
- name: GeneratedGroup240
  rules:
  - alert: HostHighCpuLoad24000
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g24000"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g24000 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g24000 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure24001
    expr: node_memory_MemAvailable_bytes{group="g24001"} / node_memory_MemTotal_bytes{group="g24001"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g24001 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g24001 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill24002
    expr: predict_linear(node_filesystem_free_bytes{group="g24002"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g24002 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g24002 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors24003
    expr: rate(node_network_receive_errs_total{group="g24003"}[2m]) + rate(node_network_transmit_errs_total{group="g24003"}[2m]) > 24003
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g24003 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g24003 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate24004
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g24004"}[2m])) / (1024*1024) > 240040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g24004 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g24004 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage24005
    expr: (1 - (node_memory_SwapFree_bytes{group="g24005"} / node_memory_SwapTotal_bytes{group="g24005"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g24005 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g24005 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching24006
    expr: rate(node_context_switches_total{group="g24006"}[5m]) > 24006000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g24006 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g24006 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew24007
    expr: abs(node_timex_offset_seconds{group="g24007"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g24007 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g24007 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills24008
    expr: increase(node_vmstat_oom_kill{group="g24008"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g24008 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g24008 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion24009
    expr: node_filefd_allocated{group="g24009"} / node_filefd_maximum{group="g24009"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g24009 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g24009 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
