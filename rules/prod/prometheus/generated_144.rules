groups:
- name: GeneratedGroup144
  rules:
  - alert: HostHighCpuLoad14400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g14400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g14400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g14400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure14401
    expr: node_memory_MemAvailable_bytes{group="g14401"} / node_memory_MemTotal_bytes{group="g14401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g14401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g14401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill14402
    expr: predict_linear(node_filesystem_free_bytes{group="g14402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g14402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g14402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors14403
    expr: rate(node_network_receive_errs_total{group="g14403"}[2m]) + rate(node_network_transmit_errs_total{group="g14403"}[2m]) > 14403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g14403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g14403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate14404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g14404"}[2m])) / (1024*1024) > 144040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g14404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g14404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage14405
    expr: (1 - (node_memory_SwapFree_bytes{group="g14405"} / node_memory_SwapTotal_bytes{group="g14405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g14405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g14405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching14406
    expr: rate(node_context_switches_total{group="g14406"}[5m]) > 14406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g14406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g14406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew14407
    expr: abs(node_timex_offset_seconds{group="g14407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g14407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g14407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills14408
    expr: increase(node_vmstat_oom_kill{group="g14408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g14408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g14408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion14409
    expr: node_filefd_allocated{group="g14409"} / node_filefd_maximum{group="g14409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g14409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g14409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
