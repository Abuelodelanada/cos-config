groups:
- name: GeneratedGroup24
  rules:
  - alert: HostHighCpuLoad2400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g2400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g2400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g2400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure2401
    expr: node_memory_MemAvailable_bytes{group="g2401"} / node_memory_MemTotal_bytes{group="g2401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g2401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g2401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill2402
    expr: predict_linear(node_filesystem_free_bytes{group="g2402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g2402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g2402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors2403
    expr: rate(node_network_receive_errs_total{group="g2403"}[2m]) + rate(node_network_transmit_errs_total{group="g2403"}[2m]) > 2403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g2403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g2403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate2404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g2404"}[2m])) / (1024*1024) > 24040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g2404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g2404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage2405
    expr: (1 - (node_memory_SwapFree_bytes{group="g2405"} / node_memory_SwapTotal_bytes{group="g2405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g2405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g2405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching2406
    expr: rate(node_context_switches_total{group="g2406"}[5m]) > 2406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g2406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g2406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew2407
    expr: abs(node_timex_offset_seconds{group="g2407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g2407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g2407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills2408
    expr: increase(node_vmstat_oom_kill{group="g2408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g2408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g2408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion2409
    expr: node_filefd_allocated{group="g2409"} / node_filefd_maximum{group="g2409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g2409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g2409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
