groups:
- name: GeneratedGroup277
  rules:
  - alert: HostHighCpuLoad27700
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g27700"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g27700 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g27700 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure27701
    expr: node_memory_MemAvailable_bytes{group="g27701"} / node_memory_MemTotal_bytes{group="g27701"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g27701 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g27701 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill27702
    expr: predict_linear(node_filesystem_free_bytes{group="g27702"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g27702 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g27702 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors27703
    expr: rate(node_network_receive_errs_total{group="g27703"}[2m]) + rate(node_network_transmit_errs_total{group="g27703"}[2m]) > 27703
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g27703 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g27703 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate27704
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g27704"}[2m])) / (1024*1024) > 277040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g27704 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g27704 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage27705
    expr: (1 - (node_memory_SwapFree_bytes{group="g27705"} / node_memory_SwapTotal_bytes{group="g27705"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g27705 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g27705 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching27706
    expr: rate(node_context_switches_total{group="g27706"}[5m]) > 27706000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g27706 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g27706 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew27707
    expr: abs(node_timex_offset_seconds{group="g27707"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g27707 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g27707 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills27708
    expr: increase(node_vmstat_oom_kill{group="g27708"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g27708 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g27708 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion27709
    expr: node_filefd_allocated{group="g27709"} / node_filefd_maximum{group="g27709"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g27709 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g27709 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
