groups:
- name: GeneratedGroup265
  rules:
  - alert: HostHighCpuLoad26500
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g26500"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g26500 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g26500 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure26501
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g26501"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g26501"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g26501 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g26501 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill26502
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g26502"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g26502 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g26502 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors26503
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g26503"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g26503"}[2m]) > 26503
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g26503 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g26503 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate26504
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g26504"}[2m])) / (1024*1024) > 265040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g26504 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g26504 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage26505
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g26505"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g26505"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g26505 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g26505 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching26506
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g26506"}[5m]) > 26506000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g26506 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g26506 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew26507
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g26507"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g26507 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g26507 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills26508
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g26508"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g26508 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g26508 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion26509
    expr: node_filefd_allocated{%%juju_topology%%,group="g26509"} / node_filefd_maximum{%%juju_topology%%,group="g26509"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g26509 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g26509 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
