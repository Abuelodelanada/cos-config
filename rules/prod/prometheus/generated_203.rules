groups:
- name: GeneratedGroup203
  rules:
  - alert: HostHighCpuLoad20300
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g20300"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g20300 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g20300 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure20301
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g20301"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g20301"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g20301 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g20301 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill20302
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g20302"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g20302 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g20302 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors20303
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g20303"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g20303"}[2m]) > 20303
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g20303 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g20303 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate20304
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g20304"}[2m])) / (1024*1024) > 203040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g20304 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g20304 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage20305
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g20305"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g20305"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g20305 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g20305 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching20306
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g20306"}[5m]) > 20306000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g20306 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g20306 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew20307
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g20307"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g20307 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g20307 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills20308
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g20308"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g20308 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g20308 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion20309
    expr: node_filefd_allocated{%%juju_topology%%,group="g20309"} / node_filefd_maximum{%%juju_topology%%,group="g20309"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g20309 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g20309 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
