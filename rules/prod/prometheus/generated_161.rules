groups:
- name: GeneratedGroup161
  rules:
  - alert: HostHighCpuLoad16100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g16100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g16100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g16100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure16101
    expr: node_memory_MemAvailable_bytes{group="g16101"} / node_memory_MemTotal_bytes{group="g16101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g16101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g16101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill16102
    expr: predict_linear(node_filesystem_free_bytes{group="g16102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g16102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g16102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors16103
    expr: rate(node_network_receive_errs_total{group="g16103"}[2m]) + rate(node_network_transmit_errs_total{group="g16103"}[2m]) > 16103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g16103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g16103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate16104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g16104"}[2m])) / (1024*1024) > 161040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g16104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g16104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage16105
    expr: (1 - (node_memory_SwapFree_bytes{group="g16105"} / node_memory_SwapTotal_bytes{group="g16105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g16105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g16105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching16106
    expr: rate(node_context_switches_total{group="g16106"}[5m]) > 16106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g16106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g16106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew16107
    expr: abs(node_timex_offset_seconds{group="g16107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g16107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g16107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills16108
    expr: increase(node_vmstat_oom_kill{group="g16108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g16108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g16108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion16109
    expr: node_filefd_allocated{group="g16109"} / node_filefd_maximum{group="g16109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g16109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g16109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
