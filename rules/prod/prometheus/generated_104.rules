groups:
- name: GeneratedGroup104
  rules:
  - alert: HostHighCpuLoad10400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g10400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g10400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g10400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure10401
    expr: node_memory_MemAvailable_bytes{group="g10401"} / node_memory_MemTotal_bytes{group="g10401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g10401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g10401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill10402
    expr: predict_linear(node_filesystem_free_bytes{group="g10402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g10402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g10402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors10403
    expr: rate(node_network_receive_errs_total{group="g10403"}[2m]) + rate(node_network_transmit_errs_total{group="g10403"}[2m]) > 10403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g10403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g10403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate10404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g10404"}[2m])) / (1024*1024) > 104040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g10404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g10404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage10405
    expr: (1 - (node_memory_SwapFree_bytes{group="g10405"} / node_memory_SwapTotal_bytes{group="g10405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g10405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g10405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching10406
    expr: rate(node_context_switches_total{group="g10406"}[5m]) > 10406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g10406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g10406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew10407
    expr: abs(node_timex_offset_seconds{group="g10407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g10407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g10407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills10408
    expr: increase(node_vmstat_oom_kill{group="g10408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g10408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g10408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion10409
    expr: node_filefd_allocated{group="g10409"} / node_filefd_maximum{group="g10409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g10409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g10409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
