groups:
- name: GeneratedGroup293
  rules:
  - alert: HostHighCpuLoad29300
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g29300"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g29300 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g29300 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure29301
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g29301"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g29301"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g29301 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g29301 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill29302
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g29302"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g29302 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g29302 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors29303
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g29303"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g29303"}[2m]) > 29303
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g29303 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g29303 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate29304
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g29304"}[2m])) / (1024*1024) > 293040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g29304 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g29304 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage29305
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g29305"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g29305"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g29305 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g29305 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching29306
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g29306"}[5m]) > 29306000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g29306 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g29306 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew29307
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g29307"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g29307 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g29307 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills29308
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g29308"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g29308 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g29308 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion29309
    expr: node_filefd_allocated{%%juju_topology%%,group="g29309"} / node_filefd_maximum{%%juju_topology%%,group="g29309"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g29309 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g29309 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
