groups:
- name: GeneratedGroup126
  rules:
  - alert: HostHighCpuLoad12600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g12600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g12600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g12600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure12601
    expr: node_memory_MemAvailable_bytes{group="g12601"} / node_memory_MemTotal_bytes{group="g12601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g12601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g12601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill12602
    expr: predict_linear(node_filesystem_free_bytes{group="g12602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g12602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g12602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors12603
    expr: rate(node_network_receive_errs_total{group="g12603"}[2m]) + rate(node_network_transmit_errs_total{group="g12603"}[2m]) > 12603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g12603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g12603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate12604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g12604"}[2m])) / (1024*1024) > 126040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g12604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g12604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage12605
    expr: (1 - (node_memory_SwapFree_bytes{group="g12605"} / node_memory_SwapTotal_bytes{group="g12605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g12605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g12605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching12606
    expr: rate(node_context_switches_total{group="g12606"}[5m]) > 12606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g12606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g12606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew12607
    expr: abs(node_timex_offset_seconds{group="g12607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g12607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g12607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills12608
    expr: increase(node_vmstat_oom_kill{group="g12608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g12608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g12608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion12609
    expr: node_filefd_allocated{group="g12609"} / node_filefd_maximum{group="g12609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g12609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g12609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
