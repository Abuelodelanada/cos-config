groups:
- name: GeneratedGroup86
  rules:
  - alert: HostHighCpuLoad8600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g8600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g8600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g8600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure8601
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g8601"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g8601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g8601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g8601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill8602
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g8602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g8602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g8602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors8603
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g8603"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g8603"}[2m]) > 8603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g8603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g8603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate8604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g8604"}[2m])) / (1024*1024) > 86040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g8604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g8604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage8605
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g8605"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g8605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g8605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g8605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching8606
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g8606"}[5m]) > 8606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g8606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g8606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew8607
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g8607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g8607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g8607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills8608
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g8608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g8608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g8608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion8609
    expr: node_filefd_allocated{%%juju_topology%%,group="g8609"} / node_filefd_maximum{%%juju_topology%%,group="g8609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g8609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g8609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
