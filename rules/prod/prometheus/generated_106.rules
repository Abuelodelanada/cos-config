groups:
- name: GeneratedGroup106
  rules:
  - alert: HostHighCpuLoad10600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g10600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g10600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g10600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure10601
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g10601"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g10601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g10601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g10601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill10602
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g10602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g10602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g10602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors10603
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g10603"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g10603"}[2m]) > 10603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g10603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g10603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate10604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g10604"}[2m])) / (1024*1024) > 106040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g10604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g10604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage10605
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g10605"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g10605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g10605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g10605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching10606
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g10606"}[5m]) > 10606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g10606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g10606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew10607
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g10607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g10607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g10607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills10608
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g10608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g10608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g10608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion10609
    expr: node_filefd_allocated{%%juju_topology%%,group="g10609"} / node_filefd_maximum{%%juju_topology%%,group="g10609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g10609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g10609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
