groups:
- name: GeneratedGroup202
  rules:
  - alert: HostHighCpuLoad20200
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g20200"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g20200 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g20200 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure20201
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g20201"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g20201"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g20201 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g20201 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill20202
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g20202"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g20202 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g20202 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors20203
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g20203"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g20203"}[2m]) > 20203
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g20203 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g20203 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate20204
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g20204"}[2m])) / (1024*1024) > 202040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g20204 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g20204 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage20205
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g20205"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g20205"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g20205 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g20205 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching20206
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g20206"}[5m]) > 20206000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g20206 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g20206 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew20207
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g20207"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g20207 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g20207 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills20208
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g20208"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g20208 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g20208 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion20209
    expr: node_filefd_allocated{%%juju_topology%%,group="g20209"} / node_filefd_maximum{%%juju_topology%%,group="g20209"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g20209 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g20209 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
