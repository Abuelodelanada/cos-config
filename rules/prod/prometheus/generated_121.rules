groups:
- name: GeneratedGroup121
  rules:
  - alert: HostHighCpuLoad12100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g12100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g12100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g12100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure12101
    expr: node_memory_MemAvailable_bytes{group="g12101"} / node_memory_MemTotal_bytes{group="g12101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g12101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g12101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill12102
    expr: predict_linear(node_filesystem_free_bytes{group="g12102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g12102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g12102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors12103
    expr: rate(node_network_receive_errs_total{group="g12103"}[2m]) + rate(node_network_transmit_errs_total{group="g12103"}[2m]) > 12103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g12103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g12103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate12104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g12104"}[2m])) / (1024*1024) > 121040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g12104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g12104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage12105
    expr: (1 - (node_memory_SwapFree_bytes{group="g12105"} / node_memory_SwapTotal_bytes{group="g12105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g12105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g12105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching12106
    expr: rate(node_context_switches_total{group="g12106"}[5m]) > 12106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g12106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g12106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew12107
    expr: abs(node_timex_offset_seconds{group="g12107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g12107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g12107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills12108
    expr: increase(node_vmstat_oom_kill{group="g12108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g12108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g12108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion12109
    expr: node_filefd_allocated{group="g12109"} / node_filefd_maximum{group="g12109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g12109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g12109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
