groups:
- name: GeneratedGroup278
  rules:
  - alert: HostHighCpuLoad27800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g27800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g27800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g27800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure27801
    expr: node_memory_MemAvailable_bytes{group="g27801"} / node_memory_MemTotal_bytes{group="g27801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g27801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g27801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill27802
    expr: predict_linear(node_filesystem_free_bytes{group="g27802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g27802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g27802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors27803
    expr: rate(node_network_receive_errs_total{group="g27803"}[2m]) + rate(node_network_transmit_errs_total{group="g27803"}[2m]) > 27803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g27803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g27803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate27804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g27804"}[2m])) / (1024*1024) > 278040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g27804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g27804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage27805
    expr: (1 - (node_memory_SwapFree_bytes{group="g27805"} / node_memory_SwapTotal_bytes{group="g27805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g27805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g27805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching27806
    expr: rate(node_context_switches_total{group="g27806"}[5m]) > 27806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g27806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g27806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew27807
    expr: abs(node_timex_offset_seconds{group="g27807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g27807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g27807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills27808
    expr: increase(node_vmstat_oom_kill{group="g27808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g27808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g27808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion27809
    expr: node_filefd_allocated{group="g27809"} / node_filefd_maximum{group="g27809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g27809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g27809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
