groups:
- name: GeneratedGroup113
  rules:
  - alert: HostHighCpuLoad11300
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g11300"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g11300 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g11300 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure11301
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g11301"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g11301"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g11301 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g11301 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill11302
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g11302"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g11302 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g11302 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors11303
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g11303"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g11303"}[2m]) > 11303
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g11303 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g11303 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate11304
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g11304"}[2m])) / (1024*1024) > 113040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g11304 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g11304 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage11305
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g11305"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g11305"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g11305 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g11305 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching11306
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g11306"}[5m]) > 11306000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g11306 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g11306 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew11307
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g11307"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g11307 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g11307 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills11308
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g11308"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g11308 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g11308 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion11309
    expr: node_filefd_allocated{%%juju_topology%%,group="g11309"} / node_filefd_maximum{%%juju_topology%%,group="g11309"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g11309 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g11309 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
