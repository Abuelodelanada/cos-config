groups:
- name: GeneratedGroup268
  rules:
  - alert: HostHighCpuLoad26800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g26800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g26800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g26800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure26801
    expr: node_memory_MemAvailable_bytes{group="g26801"} / node_memory_MemTotal_bytes{group="g26801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g26801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g26801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill26802
    expr: predict_linear(node_filesystem_free_bytes{group="g26802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g26802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g26802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors26803
    expr: rate(node_network_receive_errs_total{group="g26803"}[2m]) + rate(node_network_transmit_errs_total{group="g26803"}[2m]) > 26803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g26803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g26803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate26804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g26804"}[2m])) / (1024*1024) > 268040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g26804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g26804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage26805
    expr: (1 - (node_memory_SwapFree_bytes{group="g26805"} / node_memory_SwapTotal_bytes{group="g26805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g26805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g26805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching26806
    expr: rate(node_context_switches_total{group="g26806"}[5m]) > 26806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g26806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g26806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew26807
    expr: abs(node_timex_offset_seconds{group="g26807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g26807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g26807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills26808
    expr: increase(node_vmstat_oom_kill{group="g26808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g26808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g26808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion26809
    expr: node_filefd_allocated{group="g26809"} / node_filefd_maximum{group="g26809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g26809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g26809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
