groups:
- name: GeneratedGroup41
  rules:
  - alert: HostHighCpuLoad4100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g4100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g4100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g4100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure4101
    expr: node_memory_MemAvailable_bytes{group="g4101"} / node_memory_MemTotal_bytes{group="g4101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g4101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g4101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill4102
    expr: predict_linear(node_filesystem_free_bytes{group="g4102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g4102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g4102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors4103
    expr: rate(node_network_receive_errs_total{group="g4103"}[2m]) + rate(node_network_transmit_errs_total{group="g4103"}[2m]) > 4103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g4103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g4103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate4104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g4104"}[2m])) / (1024*1024) > 41040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g4104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g4104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage4105
    expr: (1 - (node_memory_SwapFree_bytes{group="g4105"} / node_memory_SwapTotal_bytes{group="g4105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g4105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g4105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching4106
    expr: rate(node_context_switches_total{group="g4106"}[5m]) > 4106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g4106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g4106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew4107
    expr: abs(node_timex_offset_seconds{group="g4107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g4107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g4107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills4108
    expr: increase(node_vmstat_oom_kill{group="g4108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g4108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g4108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion4109
    expr: node_filefd_allocated{group="g4109"} / node_filefd_maximum{group="g4109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g4109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g4109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
