groups:
- name: GeneratedGroup97
  rules:
  - alert: HostHighCpuLoad9700
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g9700"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g9700 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g9700 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure9701
    expr: node_memory_MemAvailable_bytes{group="g9701"} / node_memory_MemTotal_bytes{group="g9701"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g9701 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g9701 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill9702
    expr: predict_linear(node_filesystem_free_bytes{group="g9702"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g9702 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g9702 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors9703
    expr: rate(node_network_receive_errs_total{group="g9703"}[2m]) + rate(node_network_transmit_errs_total{group="g9703"}[2m]) > 9703
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g9703 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g9703 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate9704
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g9704"}[2m])) / (1024*1024) > 97040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g9704 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g9704 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage9705
    expr: (1 - (node_memory_SwapFree_bytes{group="g9705"} / node_memory_SwapTotal_bytes{group="g9705"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g9705 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g9705 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching9706
    expr: rate(node_context_switches_total{group="g9706"}[5m]) > 9706000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g9706 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g9706 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew9707
    expr: abs(node_timex_offset_seconds{group="g9707"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g9707 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g9707 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills9708
    expr: increase(node_vmstat_oom_kill{group="g9708"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g9708 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g9708 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion9709
    expr: node_filefd_allocated{group="g9709"} / node_filefd_maximum{group="g9709"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g9709 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g9709 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
