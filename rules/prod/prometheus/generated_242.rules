groups:
- name: GeneratedGroup242
  rules:
  - alert: HostHighCpuLoad24200
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g24200"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g24200 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g24200 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure24201
    expr: node_memory_MemAvailable_bytes{group="g24201"} / node_memory_MemTotal_bytes{group="g24201"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g24201 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g24201 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill24202
    expr: predict_linear(node_filesystem_free_bytes{group="g24202"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g24202 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g24202 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors24203
    expr: rate(node_network_receive_errs_total{group="g24203"}[2m]) + rate(node_network_transmit_errs_total{group="g24203"}[2m]) > 24203
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g24203 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g24203 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate24204
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g24204"}[2m])) / (1024*1024) > 242040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g24204 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g24204 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage24205
    expr: (1 - (node_memory_SwapFree_bytes{group="g24205"} / node_memory_SwapTotal_bytes{group="g24205"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g24205 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g24205 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching24206
    expr: rate(node_context_switches_total{group="g24206"}[5m]) > 24206000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g24206 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g24206 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew24207
    expr: abs(node_timex_offset_seconds{group="g24207"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g24207 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g24207 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills24208
    expr: increase(node_vmstat_oom_kill{group="g24208"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g24208 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g24208 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion24209
    expr: node_filefd_allocated{group="g24209"} / node_filefd_maximum{group="g24209"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g24209 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g24209 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
