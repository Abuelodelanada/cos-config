groups:
- name: GeneratedGroup175
  rules:
  - alert: HostHighCpuLoad17500
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g17500"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g17500 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g17500 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure17501
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g17501"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g17501"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g17501 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g17501 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill17502
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g17502"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g17502 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g17502 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors17503
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g17503"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g17503"}[2m]) > 17503
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g17503 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g17503 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate17504
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g17504"}[2m])) / (1024*1024) > 175040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g17504 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g17504 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage17505
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g17505"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g17505"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g17505 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g17505 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching17506
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g17506"}[5m]) > 17506000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g17506 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g17506 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew17507
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g17507"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g17507 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g17507 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills17508
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g17508"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g17508 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g17508 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion17509
    expr: node_filefd_allocated{%%juju_topology%%,group="g17509"} / node_filefd_maximum{%%juju_topology%%,group="g17509"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g17509 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g17509 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
