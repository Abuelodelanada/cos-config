groups:
- name: GeneratedGroup34
  rules:
  - alert: HostHighCpuLoad3400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g3400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g3400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g3400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure3401
    expr: node_memory_MemAvailable_bytes{group="g3401"} / node_memory_MemTotal_bytes{group="g3401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g3401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g3401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill3402
    expr: predict_linear(node_filesystem_free_bytes{group="g3402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g3402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g3402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors3403
    expr: rate(node_network_receive_errs_total{group="g3403"}[2m]) + rate(node_network_transmit_errs_total{group="g3403"}[2m]) > 3403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g3403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g3403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate3404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g3404"}[2m])) / (1024*1024) > 34040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g3404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g3404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage3405
    expr: (1 - (node_memory_SwapFree_bytes{group="g3405"} / node_memory_SwapTotal_bytes{group="g3405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g3405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g3405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching3406
    expr: rate(node_context_switches_total{group="g3406"}[5m]) > 3406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g3406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g3406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew3407
    expr: abs(node_timex_offset_seconds{group="g3407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g3407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g3407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills3408
    expr: increase(node_vmstat_oom_kill{group="g3408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g3408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g3408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion3409
    expr: node_filefd_allocated{group="g3409"} / node_filefd_maximum{group="g3409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g3409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g3409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
