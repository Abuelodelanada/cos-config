groups:
- name: GeneratedGroup94
  rules:
  - alert: HostHighCpuLoad9400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g9400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g9400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g9400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure9401
    expr: node_memory_MemAvailable_bytes{group="g9401"} / node_memory_MemTotal_bytes{group="g9401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g9401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g9401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill9402
    expr: predict_linear(node_filesystem_free_bytes{group="g9402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g9402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g9402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors9403
    expr: rate(node_network_receive_errs_total{group="g9403"}[2m]) + rate(node_network_transmit_errs_total{group="g9403"}[2m]) > 9403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g9403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g9403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate9404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g9404"}[2m])) / (1024*1024) > 94040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g9404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g9404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage9405
    expr: (1 - (node_memory_SwapFree_bytes{group="g9405"} / node_memory_SwapTotal_bytes{group="g9405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g9405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g9405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching9406
    expr: rate(node_context_switches_total{group="g9406"}[5m]) > 9406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g9406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g9406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew9407
    expr: abs(node_timex_offset_seconds{group="g9407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g9407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g9407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills9408
    expr: increase(node_vmstat_oom_kill{group="g9408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g9408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g9408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion9409
    expr: node_filefd_allocated{group="g9409"} / node_filefd_maximum{group="g9409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g9409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g9409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
