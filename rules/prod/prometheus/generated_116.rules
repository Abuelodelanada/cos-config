groups:
- name: GeneratedGroup116
  rules:
  - alert: HostHighCpuLoad11600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g11600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g11600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g11600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure11601
    expr: node_memory_MemAvailable_bytes{group="g11601"} / node_memory_MemTotal_bytes{group="g11601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g11601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g11601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill11602
    expr: predict_linear(node_filesystem_free_bytes{group="g11602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g11602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g11602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors11603
    expr: rate(node_network_receive_errs_total{group="g11603"}[2m]) + rate(node_network_transmit_errs_total{group="g11603"}[2m]) > 11603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g11603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g11603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate11604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g11604"}[2m])) / (1024*1024) > 116040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g11604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g11604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage11605
    expr: (1 - (node_memory_SwapFree_bytes{group="g11605"} / node_memory_SwapTotal_bytes{group="g11605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g11605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g11605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching11606
    expr: rate(node_context_switches_total{group="g11606"}[5m]) > 11606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g11606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g11606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew11607
    expr: abs(node_timex_offset_seconds{group="g11607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g11607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g11607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills11608
    expr: increase(node_vmstat_oom_kill{group="g11608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g11608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g11608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion11609
    expr: node_filefd_allocated{group="g11609"} / node_filefd_maximum{group="g11609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g11609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g11609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
