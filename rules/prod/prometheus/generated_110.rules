groups:
- name: GeneratedGroup110
  rules:
  - alert: HostHighCpuLoad11000
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g11000"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g11000 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g11000 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure11001
    expr: node_memory_MemAvailable_bytes{group="g11001"} / node_memory_MemTotal_bytes{group="g11001"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g11001 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g11001 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill11002
    expr: predict_linear(node_filesystem_free_bytes{group="g11002"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g11002 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g11002 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors11003
    expr: rate(node_network_receive_errs_total{group="g11003"}[2m]) + rate(node_network_transmit_errs_total{group="g11003"}[2m]) > 11003
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g11003 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g11003 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate11004
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g11004"}[2m])) / (1024*1024) > 110040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g11004 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g11004 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage11005
    expr: (1 - (node_memory_SwapFree_bytes{group="g11005"} / node_memory_SwapTotal_bytes{group="g11005"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g11005 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g11005 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching11006
    expr: rate(node_context_switches_total{group="g11006"}[5m]) > 11006000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g11006 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g11006 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew11007
    expr: abs(node_timex_offset_seconds{group="g11007"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g11007 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g11007 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills11008
    expr: increase(node_vmstat_oom_kill{group="g11008"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g11008 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g11008 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion11009
    expr: node_filefd_allocated{group="g11009"} / node_filefd_maximum{group="g11009"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g11009 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g11009 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
