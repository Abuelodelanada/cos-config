groups:
- name: GeneratedGroup280
  rules:
  - alert: HostHighCpuLoad28000
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g28000"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g28000 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g28000 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure28001
    expr: node_memory_MemAvailable_bytes{group="g28001"} / node_memory_MemTotal_bytes{group="g28001"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g28001 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g28001 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill28002
    expr: predict_linear(node_filesystem_free_bytes{group="g28002"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g28002 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g28002 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors28003
    expr: rate(node_network_receive_errs_total{group="g28003"}[2m]) + rate(node_network_transmit_errs_total{group="g28003"}[2m]) > 28003
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g28003 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g28003 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate28004
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g28004"}[2m])) / (1024*1024) > 280040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g28004 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g28004 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage28005
    expr: (1 - (node_memory_SwapFree_bytes{group="g28005"} / node_memory_SwapTotal_bytes{group="g28005"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g28005 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g28005 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching28006
    expr: rate(node_context_switches_total{group="g28006"}[5m]) > 28006000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g28006 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g28006 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew28007
    expr: abs(node_timex_offset_seconds{group="g28007"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g28007 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g28007 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills28008
    expr: increase(node_vmstat_oom_kill{group="g28008"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g28008 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g28008 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion28009
    expr: node_filefd_allocated{group="g28009"} / node_filefd_maximum{group="g28009"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g28009 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g28009 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
