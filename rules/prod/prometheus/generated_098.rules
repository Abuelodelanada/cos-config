groups:
- name: GeneratedGroup98
  rules:
  - alert: HostHighCpuLoad9800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g9800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g9800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g9800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure9801
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g9801"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g9801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g9801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g9801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill9802
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g9802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g9802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g9802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors9803
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g9803"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g9803"}[2m]) > 9803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g9803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g9803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate9804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g9804"}[2m])) / (1024*1024) > 98040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g9804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g9804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage9805
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g9805"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g9805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g9805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g9805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching9806
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g9806"}[5m]) > 9806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g9806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g9806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew9807
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g9807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g9807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g9807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills9808
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g9808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g9808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g9808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion9809
    expr: node_filefd_allocated{%%juju_topology%%,group="g9809"} / node_filefd_maximum{%%juju_topology%%,group="g9809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g9809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g9809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
