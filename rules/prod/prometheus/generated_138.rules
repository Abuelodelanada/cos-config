groups:
- name: GeneratedGroup138
  rules:
  - alert: HostHighCpuLoad13800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g13800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g13800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g13800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure13801
    expr: node_memory_MemAvailable_bytes{group="g13801"} / node_memory_MemTotal_bytes{group="g13801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g13801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g13801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill13802
    expr: predict_linear(node_filesystem_free_bytes{group="g13802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g13802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g13802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors13803
    expr: rate(node_network_receive_errs_total{group="g13803"}[2m]) + rate(node_network_transmit_errs_total{group="g13803"}[2m]) > 13803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g13803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g13803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate13804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g13804"}[2m])) / (1024*1024) > 138040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g13804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g13804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage13805
    expr: (1 - (node_memory_SwapFree_bytes{group="g13805"} / node_memory_SwapTotal_bytes{group="g13805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g13805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g13805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching13806
    expr: rate(node_context_switches_total{group="g13806"}[5m]) > 13806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g13806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g13806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew13807
    expr: abs(node_timex_offset_seconds{group="g13807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g13807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g13807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills13808
    expr: increase(node_vmstat_oom_kill{group="g13808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g13808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g13808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion13809
    expr: node_filefd_allocated{group="g13809"} / node_filefd_maximum{group="g13809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g13809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g13809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
