groups:
- name: GeneratedGroup20
  rules:
  - alert: HostHighCpuLoad2000
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g2000"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g2000 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g2000 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure2001
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g2001"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g2001"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g2001 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g2001 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill2002
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g2002"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g2002 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g2002 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors2003
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g2003"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g2003"}[2m]) > 2003
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g2003 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g2003 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate2004
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g2004"}[2m])) / (1024*1024) > 20040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g2004 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g2004 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage2005
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g2005"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g2005"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g2005 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g2005 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching2006
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g2006"}[5m]) > 2006000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g2006 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g2006 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew2007
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g2007"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g2007 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g2007 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills2008
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g2008"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g2008 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g2008 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion2009
    expr: node_filefd_allocated{%%juju_topology%%,group="g2009"} / node_filefd_maximum{%%juju_topology%%,group="g2009"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g2009 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g2009 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
