groups:
- name: GeneratedGroup226
  rules:
  - alert: HostHighCpuLoad22600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g22600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g22600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g22600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure22601
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g22601"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g22601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g22601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g22601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill22602
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g22602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g22602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g22602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors22603
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g22603"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g22603"}[2m]) > 22603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g22603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g22603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate22604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g22604"}[2m])) / (1024*1024) > 226040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g22604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g22604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage22605
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g22605"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g22605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g22605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g22605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching22606
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g22606"}[5m]) > 22606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g22606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g22606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew22607
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g22607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g22607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g22607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills22608
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g22608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g22608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g22608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion22609
    expr: node_filefd_allocated{%%juju_topology%%,group="g22609"} / node_filefd_maximum{%%juju_topology%%,group="g22609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g22609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g22609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
