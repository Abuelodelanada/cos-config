groups:
- name: GeneratedGroup15
  rules:
  - alert: HostHighCpuLoad1500
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g1500"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g1500 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g1500 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure1501
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g1501"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g1501"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g1501 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g1501 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill1502
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g1502"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g1502 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g1502 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors1503
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g1503"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g1503"}[2m]) > 1503
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g1503 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g1503 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate1504
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g1504"}[2m])) / (1024*1024) > 15040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g1504 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g1504 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage1505
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g1505"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g1505"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g1505 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g1505 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching1506
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g1506"}[5m]) > 1506000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g1506 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g1506 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew1507
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g1507"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g1507 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g1507 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills1508
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g1508"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g1508 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g1508 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion1509
    expr: node_filefd_allocated{%%juju_topology%%,group="g1509"} / node_filefd_maximum{%%juju_topology%%,group="g1509"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g1509 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g1509 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
