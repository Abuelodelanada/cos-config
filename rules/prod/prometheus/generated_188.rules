groups:
- name: GeneratedGroup188
  rules:
  - alert: HostHighCpuLoad18800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g18800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g18800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g18800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure18801
    expr: node_memory_MemAvailable_bytes{group="g18801"} / node_memory_MemTotal_bytes{group="g18801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g18801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g18801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill18802
    expr: predict_linear(node_filesystem_free_bytes{group="g18802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g18802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g18802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors18803
    expr: rate(node_network_receive_errs_total{group="g18803"}[2m]) + rate(node_network_transmit_errs_total{group="g18803"}[2m]) > 18803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g18803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g18803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate18804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g18804"}[2m])) / (1024*1024) > 188040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g18804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g18804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage18805
    expr: (1 - (node_memory_SwapFree_bytes{group="g18805"} / node_memory_SwapTotal_bytes{group="g18805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g18805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g18805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching18806
    expr: rate(node_context_switches_total{group="g18806"}[5m]) > 18806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g18806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g18806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew18807
    expr: abs(node_timex_offset_seconds{group="g18807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g18807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g18807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills18808
    expr: increase(node_vmstat_oom_kill{group="g18808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g18808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g18808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion18809
    expr: node_filefd_allocated{group="g18809"} / node_filefd_maximum{group="g18809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g18809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g18809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
