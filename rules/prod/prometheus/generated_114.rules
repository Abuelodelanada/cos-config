groups:
- name: GeneratedGroup114
  rules:
  - alert: HostHighCpuLoad11400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g11400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g11400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g11400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure11401
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g11401"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g11401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g11401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g11401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill11402
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g11402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g11402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g11402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors11403
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g11403"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g11403"}[2m]) > 11403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g11403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g11403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate11404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g11404"}[2m])) / (1024*1024) > 114040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g11404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g11404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage11405
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g11405"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g11405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g11405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g11405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching11406
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g11406"}[5m]) > 11406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g11406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g11406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew11407
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g11407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g11407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g11407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills11408
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g11408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g11408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g11408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion11409
    expr: node_filefd_allocated{%%juju_topology%%,group="g11409"} / node_filefd_maximum{%%juju_topology%%,group="g11409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g11409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g11409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
