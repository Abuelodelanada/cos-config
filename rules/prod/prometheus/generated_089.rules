groups:
- name: GeneratedGroup89
  rules:
  - alert: HostHighCpuLoad8900
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g8900"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g8900 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g8900 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure8901
    expr: node_memory_MemAvailable_bytes{group="g8901"} / node_memory_MemTotal_bytes{group="g8901"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g8901 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g8901 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill8902
    expr: predict_linear(node_filesystem_free_bytes{group="g8902"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g8902 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g8902 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors8903
    expr: rate(node_network_receive_errs_total{group="g8903"}[2m]) + rate(node_network_transmit_errs_total{group="g8903"}[2m]) > 8903
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g8903 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g8903 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate8904
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g8904"}[2m])) / (1024*1024) > 89040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g8904 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g8904 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage8905
    expr: (1 - (node_memory_SwapFree_bytes{group="g8905"} / node_memory_SwapTotal_bytes{group="g8905"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g8905 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g8905 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching8906
    expr: rate(node_context_switches_total{group="g8906"}[5m]) > 8906000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g8906 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g8906 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew8907
    expr: abs(node_timex_offset_seconds{group="g8907"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g8907 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g8907 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills8908
    expr: increase(node_vmstat_oom_kill{group="g8908"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g8908 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g8908 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion8909
    expr: node_filefd_allocated{group="g8909"} / node_filefd_maximum{group="g8909"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g8909 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g8909 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
