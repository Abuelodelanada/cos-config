groups:
- name: GeneratedGroup208
  rules:
  - alert: HostHighCpuLoad20800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g20800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g20800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g20800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure20801
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g20801"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g20801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g20801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g20801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill20802
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g20802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g20802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g20802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors20803
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g20803"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g20803"}[2m]) > 20803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g20803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g20803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate20804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g20804"}[2m])) / (1024*1024) > 208040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g20804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g20804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage20805
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g20805"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g20805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g20805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g20805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching20806
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g20806"}[5m]) > 20806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g20806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g20806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew20807
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g20807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g20807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g20807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills20808
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g20808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g20808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g20808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion20809
    expr: node_filefd_allocated{%%juju_topology%%,group="g20809"} / node_filefd_maximum{%%juju_topology%%,group="g20809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g20809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g20809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
