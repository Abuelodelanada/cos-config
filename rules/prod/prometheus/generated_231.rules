groups:
- name: GeneratedGroup231
  rules:
  - alert: HostHighCpuLoad23100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g23100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g23100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g23100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure23101
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g23101"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g23101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g23101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g23101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill23102
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g23102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g23102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g23102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors23103
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g23103"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g23103"}[2m]) > 23103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g23103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g23103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate23104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g23104"}[2m])) / (1024*1024) > 231040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g23104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g23104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage23105
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g23105"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g23105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g23105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g23105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching23106
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g23106"}[5m]) > 23106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g23106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g23106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew23107
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g23107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g23107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g23107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills23108
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g23108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g23108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g23108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion23109
    expr: node_filefd_allocated{%%juju_topology%%,group="g23109"} / node_filefd_maximum{%%juju_topology%%,group="g23109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g23109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g23109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
