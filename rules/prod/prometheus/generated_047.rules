groups:
- name: GeneratedGroup47
  rules:
  - alert: HostHighCpuLoad4700
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g4700"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g4700 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g4700 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure4701
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g4701"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g4701"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g4701 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g4701 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill4702
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g4702"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g4702 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g4702 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors4703
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g4703"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g4703"}[2m]) > 4703
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g4703 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g4703 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate4704
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g4704"}[2m])) / (1024*1024) > 47040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g4704 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g4704 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage4705
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g4705"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g4705"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g4705 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g4705 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching4706
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g4706"}[5m]) > 4706000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g4706 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g4706 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew4707
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g4707"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g4707 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g4707 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills4708
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g4708"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g4708 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g4708 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion4709
    expr: node_filefd_allocated{%%juju_topology%%,group="g4709"} / node_filefd_maximum{%%juju_topology%%,group="g4709"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g4709 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g4709 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
