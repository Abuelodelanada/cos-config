groups:
- name: GeneratedGroup154
  rules:
  - alert: HostHighCpuLoad15400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g15400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g15400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g15400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure15401
    expr: node_memory_MemAvailable_bytes{group="g15401"} / node_memory_MemTotal_bytes{group="g15401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g15401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g15401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill15402
    expr: predict_linear(node_filesystem_free_bytes{group="g15402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g15402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g15402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors15403
    expr: rate(node_network_receive_errs_total{group="g15403"}[2m]) + rate(node_network_transmit_errs_total{group="g15403"}[2m]) > 15403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g15403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g15403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate15404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g15404"}[2m])) / (1024*1024) > 154040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g15404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g15404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage15405
    expr: (1 - (node_memory_SwapFree_bytes{group="g15405"} / node_memory_SwapTotal_bytes{group="g15405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g15405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g15405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching15406
    expr: rate(node_context_switches_total{group="g15406"}[5m]) > 15406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g15406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g15406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew15407
    expr: abs(node_timex_offset_seconds{group="g15407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g15407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g15407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills15408
    expr: increase(node_vmstat_oom_kill{group="g15408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g15408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g15408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion15409
    expr: node_filefd_allocated{group="g15409"} / node_filefd_maximum{group="g15409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g15409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g15409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
