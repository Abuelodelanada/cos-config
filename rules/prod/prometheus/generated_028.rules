groups:
- name: GeneratedGroup28
  rules:
  - alert: HostHighCpuLoad2800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g2800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g2800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g2800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure2801
    expr: node_memory_MemAvailable_bytes{group="g2801"} / node_memory_MemTotal_bytes{group="g2801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g2801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g2801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill2802
    expr: predict_linear(node_filesystem_free_bytes{group="g2802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g2802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g2802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors2803
    expr: rate(node_network_receive_errs_total{group="g2803"}[2m]) + rate(node_network_transmit_errs_total{group="g2803"}[2m]) > 2803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g2803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g2803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate2804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g2804"}[2m])) / (1024*1024) > 28040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g2804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g2804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage2805
    expr: (1 - (node_memory_SwapFree_bytes{group="g2805"} / node_memory_SwapTotal_bytes{group="g2805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g2805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g2805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching2806
    expr: rate(node_context_switches_total{group="g2806"}[5m]) > 2806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g2806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g2806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew2807
    expr: abs(node_timex_offset_seconds{group="g2807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g2807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g2807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills2808
    expr: increase(node_vmstat_oom_kill{group="g2808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g2808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g2808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion2809
    expr: node_filefd_allocated{group="g2809"} / node_filefd_maximum{group="g2809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g2809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g2809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
