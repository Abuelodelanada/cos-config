groups:
- name: GeneratedGroup143
  rules:
  - alert: HostHighCpuLoad14300
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g14300"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g14300 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g14300 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure14301
    expr: node_memory_MemAvailable_bytes{group="g14301"} / node_memory_MemTotal_bytes{group="g14301"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g14301 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g14301 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill14302
    expr: predict_linear(node_filesystem_free_bytes{group="g14302"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g14302 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g14302 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors14303
    expr: rate(node_network_receive_errs_total{group="g14303"}[2m]) + rate(node_network_transmit_errs_total{group="g14303"}[2m]) > 14303
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g14303 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g14303 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate14304
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g14304"}[2m])) / (1024*1024) > 143040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g14304 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g14304 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage14305
    expr: (1 - (node_memory_SwapFree_bytes{group="g14305"} / node_memory_SwapTotal_bytes{group="g14305"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g14305 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g14305 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching14306
    expr: rate(node_context_switches_total{group="g14306"}[5m]) > 14306000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g14306 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g14306 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew14307
    expr: abs(node_timex_offset_seconds{group="g14307"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g14307 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g14307 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills14308
    expr: increase(node_vmstat_oom_kill{group="g14308"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g14308 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g14308 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion14309
    expr: node_filefd_allocated{group="g14309"} / node_filefd_maximum{group="g14309"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g14309 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g14309 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
