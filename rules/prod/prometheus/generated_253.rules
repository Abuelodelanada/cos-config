groups:
- name: GeneratedGroup253
  rules:
  - alert: HostHighCpuLoad25300
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g25300"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g25300 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g25300 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure25301
    expr: node_memory_MemAvailable_bytes{group="g25301"} / node_memory_MemTotal_bytes{group="g25301"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g25301 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g25301 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill25302
    expr: predict_linear(node_filesystem_free_bytes{group="g25302"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g25302 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g25302 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors25303
    expr: rate(node_network_receive_errs_total{group="g25303"}[2m]) + rate(node_network_transmit_errs_total{group="g25303"}[2m]) > 25303
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g25303 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g25303 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate25304
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g25304"}[2m])) / (1024*1024) > 253040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g25304 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g25304 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage25305
    expr: (1 - (node_memory_SwapFree_bytes{group="g25305"} / node_memory_SwapTotal_bytes{group="g25305"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g25305 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g25305 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching25306
    expr: rate(node_context_switches_total{group="g25306"}[5m]) > 25306000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g25306 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g25306 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew25307
    expr: abs(node_timex_offset_seconds{group="g25307"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g25307 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g25307 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills25308
    expr: increase(node_vmstat_oom_kill{group="g25308"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g25308 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g25308 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion25309
    expr: node_filefd_allocated{group="g25309"} / node_filefd_maximum{group="g25309"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g25309 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g25309 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
