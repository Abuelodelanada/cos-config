groups:
- name: GeneratedGroup156
  rules:
  - alert: HostHighCpuLoad15600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g15600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g15600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g15600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure15601
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g15601"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g15601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g15601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g15601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill15602
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g15602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g15602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g15602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors15603
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g15603"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g15603"}[2m]) > 15603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g15603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g15603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate15604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g15604"}[2m])) / (1024*1024) > 156040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g15604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g15604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage15605
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g15605"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g15605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g15605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g15605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching15606
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g15606"}[5m]) > 15606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g15606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g15606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew15607
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g15607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g15607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g15607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills15608
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g15608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g15608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g15608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion15609
    expr: node_filefd_allocated{%%juju_topology%%,group="g15609"} / node_filefd_maximum{%%juju_topology%%,group="g15609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g15609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g15609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
