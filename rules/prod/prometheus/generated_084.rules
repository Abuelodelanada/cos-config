groups:
- name: GeneratedGroup84
  rules:
  - alert: HostHighCpuLoad8400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g8400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g8400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g8400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure8401
    expr: node_memory_MemAvailable_bytes{group="g8401"} / node_memory_MemTotal_bytes{group="g8401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g8401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g8401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill8402
    expr: predict_linear(node_filesystem_free_bytes{group="g8402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g8402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g8402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors8403
    expr: rate(node_network_receive_errs_total{group="g8403"}[2m]) + rate(node_network_transmit_errs_total{group="g8403"}[2m]) > 8403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g8403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g8403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate8404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g8404"}[2m])) / (1024*1024) > 84040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g8404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g8404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage8405
    expr: (1 - (node_memory_SwapFree_bytes{group="g8405"} / node_memory_SwapTotal_bytes{group="g8405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g8405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g8405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching8406
    expr: rate(node_context_switches_total{group="g8406"}[5m]) > 8406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g8406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g8406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew8407
    expr: abs(node_timex_offset_seconds{group="g8407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g8407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g8407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills8408
    expr: increase(node_vmstat_oom_kill{group="g8408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g8408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g8408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion8409
    expr: node_filefd_allocated{group="g8409"} / node_filefd_maximum{group="g8409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g8409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g8409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
