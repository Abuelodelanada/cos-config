groups:
- name: GeneratedGroup221
  rules:
  - alert: HostHighCpuLoad22100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g22100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g22100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g22100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure22101
    expr: node_memory_MemAvailable_bytes{group="g22101"} / node_memory_MemTotal_bytes{group="g22101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g22101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g22101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill22102
    expr: predict_linear(node_filesystem_free_bytes{group="g22102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g22102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g22102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors22103
    expr: rate(node_network_receive_errs_total{group="g22103"}[2m]) + rate(node_network_transmit_errs_total{group="g22103"}[2m]) > 22103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g22103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g22103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate22104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g22104"}[2m])) / (1024*1024) > 221040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g22104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g22104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage22105
    expr: (1 - (node_memory_SwapFree_bytes{group="g22105"} / node_memory_SwapTotal_bytes{group="g22105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g22105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g22105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching22106
    expr: rate(node_context_switches_total{group="g22106"}[5m]) > 22106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g22106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g22106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew22107
    expr: abs(node_timex_offset_seconds{group="g22107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g22107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g22107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills22108
    expr: increase(node_vmstat_oom_kill{group="g22108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g22108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g22108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion22109
    expr: node_filefd_allocated{group="g22109"} / node_filefd_maximum{group="g22109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g22109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g22109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
