groups:
- name: GeneratedGroup42
  rules:
  - alert: HostHighCpuLoad4200
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g4200"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g4200 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g4200 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure4201
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g4201"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g4201"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g4201 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g4201 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill4202
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g4202"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g4202 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g4202 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors4203
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g4203"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g4203"}[2m]) > 4203
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g4203 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g4203 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate4204
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g4204"}[2m])) / (1024*1024) > 42040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g4204 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g4204 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage4205
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g4205"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g4205"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g4205 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g4205 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching4206
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g4206"}[5m]) > 4206000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g4206 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g4206 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew4207
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g4207"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g4207 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g4207 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills4208
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g4208"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g4208 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g4208 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion4209
    expr: node_filefd_allocated{%%juju_topology%%,group="g4209"} / node_filefd_maximum{%%juju_topology%%,group="g4209"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g4209 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g4209 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
