groups:
- name: GeneratedGroup59
  rules:
  - alert: HostHighCpuLoad5900
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g5900"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g5900 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g5900 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure5901
    expr: node_memory_MemAvailable_bytes{group="g5901"} / node_memory_MemTotal_bytes{group="g5901"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g5901 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g5901 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill5902
    expr: predict_linear(node_filesystem_free_bytes{group="g5902"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g5902 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g5902 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors5903
    expr: rate(node_network_receive_errs_total{group="g5903"}[2m]) + rate(node_network_transmit_errs_total{group="g5903"}[2m]) > 5903
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g5903 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g5903 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate5904
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g5904"}[2m])) / (1024*1024) > 59040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g5904 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g5904 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage5905
    expr: (1 - (node_memory_SwapFree_bytes{group="g5905"} / node_memory_SwapTotal_bytes{group="g5905"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g5905 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g5905 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching5906
    expr: rate(node_context_switches_total{group="g5906"}[5m]) > 5906000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g5906 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g5906 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew5907
    expr: abs(node_timex_offset_seconds{group="g5907"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g5907 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g5907 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills5908
    expr: increase(node_vmstat_oom_kill{group="g5908"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g5908 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g5908 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion5909
    expr: node_filefd_allocated{group="g5909"} / node_filefd_maximum{group="g5909"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g5909 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g5909 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
