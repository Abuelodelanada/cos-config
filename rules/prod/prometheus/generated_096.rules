groups:
- name: GeneratedGroup96
  rules:
  - alert: HostHighCpuLoad9600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g9600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g9600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g9600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure9601
    expr: node_memory_MemAvailable_bytes{group="g9601"} / node_memory_MemTotal_bytes{group="g9601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g9601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g9601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill9602
    expr: predict_linear(node_filesystem_free_bytes{group="g9602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g9602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g9602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors9603
    expr: rate(node_network_receive_errs_total{group="g9603"}[2m]) + rate(node_network_transmit_errs_total{group="g9603"}[2m]) > 9603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g9603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g9603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate9604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g9604"}[2m])) / (1024*1024) > 96040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g9604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g9604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage9605
    expr: (1 - (node_memory_SwapFree_bytes{group="g9605"} / node_memory_SwapTotal_bytes{group="g9605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g9605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g9605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching9606
    expr: rate(node_context_switches_total{group="g9606"}[5m]) > 9606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g9606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g9606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew9607
    expr: abs(node_timex_offset_seconds{group="g9607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g9607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g9607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills9608
    expr: increase(node_vmstat_oom_kill{group="g9608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g9608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g9608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion9609
    expr: node_filefd_allocated{group="g9609"} / node_filefd_maximum{group="g9609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g9609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g9609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
