groups:
- name: GeneratedGroup91
  rules:
  - alert: HostHighCpuLoad9100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g9100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g9100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g9100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure9101
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g9101"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g9101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g9101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g9101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill9102
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g9102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g9102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g9102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors9103
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g9103"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g9103"}[2m]) > 9103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g9103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g9103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate9104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g9104"}[2m])) / (1024*1024) > 91040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g9104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g9104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage9105
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g9105"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g9105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g9105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g9105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching9106
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g9106"}[5m]) > 9106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g9106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g9106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew9107
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g9107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g9107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g9107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills9108
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g9108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g9108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g9108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion9109
    expr: node_filefd_allocated{%%juju_topology%%,group="g9109"} / node_filefd_maximum{%%juju_topology%%,group="g9109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g9109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g9109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
