groups:
- name: GeneratedGroup284
  rules:
  - alert: HostHighCpuLoad28400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g28400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g28400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g28400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure28401
    expr: node_memory_MemAvailable_bytes{group="g28401"} / node_memory_MemTotal_bytes{group="g28401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g28401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g28401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill28402
    expr: predict_linear(node_filesystem_free_bytes{group="g28402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g28402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g28402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors28403
    expr: rate(node_network_receive_errs_total{group="g28403"}[2m]) + rate(node_network_transmit_errs_total{group="g28403"}[2m]) > 28403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g28403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g28403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate28404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g28404"}[2m])) / (1024*1024) > 284040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g28404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g28404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage28405
    expr: (1 - (node_memory_SwapFree_bytes{group="g28405"} / node_memory_SwapTotal_bytes{group="g28405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g28405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g28405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching28406
    expr: rate(node_context_switches_total{group="g28406"}[5m]) > 28406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g28406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g28406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew28407
    expr: abs(node_timex_offset_seconds{group="g28407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g28407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g28407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills28408
    expr: increase(node_vmstat_oom_kill{group="g28408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g28408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g28408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion28409
    expr: node_filefd_allocated{group="g28409"} / node_filefd_maximum{group="g28409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g28409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g28409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
