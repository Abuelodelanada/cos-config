groups:
- name: GeneratedGroup57
  rules:
  - alert: HostHighCpuLoad5700
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g5700"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g5700 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g5700 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure5701
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g5701"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g5701"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g5701 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g5701 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill5702
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g5702"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g5702 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g5702 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors5703
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g5703"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g5703"}[2m]) > 5703
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g5703 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g5703 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate5704
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g5704"}[2m])) / (1024*1024) > 57040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g5704 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g5704 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage5705
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g5705"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g5705"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g5705 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g5705 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching5706
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g5706"}[5m]) > 5706000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g5706 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g5706 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew5707
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g5707"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g5707 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g5707 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills5708
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g5708"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g5708 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g5708 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion5709
    expr: node_filefd_allocated{%%juju_topology%%,group="g5709"} / node_filefd_maximum{%%juju_topology%%,group="g5709"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g5709 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g5709 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
