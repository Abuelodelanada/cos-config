groups:
- name: GeneratedGroup206
  rules:
  - alert: HostHighCpuLoad20600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g20600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g20600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g20600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure20601
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g20601"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g20601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g20601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g20601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill20602
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g20602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g20602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g20602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors20603
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g20603"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g20603"}[2m]) > 20603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g20603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g20603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate20604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g20604"}[2m])) / (1024*1024) > 206040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g20604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g20604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage20605
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g20605"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g20605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g20605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g20605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching20606
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g20606"}[5m]) > 20606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g20606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g20606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew20607
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g20607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g20607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g20607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills20608
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g20608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g20608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g20608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion20609
    expr: node_filefd_allocated{%%juju_topology%%,group="g20609"} / node_filefd_maximum{%%juju_topology%%,group="g20609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g20609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g20609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
