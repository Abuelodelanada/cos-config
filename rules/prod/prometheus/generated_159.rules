groups:
- name: GeneratedGroup159
  rules:
  - alert: HostHighCpuLoad15900
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g15900"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g15900 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g15900 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure15901
    expr: node_memory_MemAvailable_bytes{group="g15901"} / node_memory_MemTotal_bytes{group="g15901"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g15901 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g15901 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill15902
    expr: predict_linear(node_filesystem_free_bytes{group="g15902"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g15902 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g15902 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors15903
    expr: rate(node_network_receive_errs_total{group="g15903"}[2m]) + rate(node_network_transmit_errs_total{group="g15903"}[2m]) > 15903
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g15903 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g15903 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate15904
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g15904"}[2m])) / (1024*1024) > 159040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g15904 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g15904 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage15905
    expr: (1 - (node_memory_SwapFree_bytes{group="g15905"} / node_memory_SwapTotal_bytes{group="g15905"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g15905 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g15905 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching15906
    expr: rate(node_context_switches_total{group="g15906"}[5m]) > 15906000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g15906 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g15906 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew15907
    expr: abs(node_timex_offset_seconds{group="g15907"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g15907 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g15907 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills15908
    expr: increase(node_vmstat_oom_kill{group="g15908"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g15908 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g15908 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion15909
    expr: node_filefd_allocated{group="g15909"} / node_filefd_maximum{group="g15909"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g15909 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g15909 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
