groups:
- name: GeneratedGroup111
  rules:
  - alert: HostHighCpuLoad11100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g11100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g11100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g11100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure11101
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g11101"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g11101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g11101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g11101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill11102
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g11102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g11102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g11102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors11103
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g11103"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g11103"}[2m]) > 11103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g11103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g11103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate11104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g11104"}[2m])) / (1024*1024) > 111040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g11104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g11104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage11105
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g11105"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g11105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g11105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g11105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching11106
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g11106"}[5m]) > 11106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g11106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g11106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew11107
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g11107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g11107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g11107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills11108
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g11108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g11108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g11108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion11109
    expr: node_filefd_allocated{%%juju_topology%%,group="g11109"} / node_filefd_maximum{%%juju_topology%%,group="g11109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g11109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g11109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
