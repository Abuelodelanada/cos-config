groups:
- name: GeneratedGroup195
  rules:
  - alert: HostHighCpuLoad19500
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g19500"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g19500 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g19500 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure19501
    expr: node_memory_MemAvailable_bytes{group="g19501"} / node_memory_MemTotal_bytes{group="g19501"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g19501 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g19501 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill19502
    expr: predict_linear(node_filesystem_free_bytes{group="g19502"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g19502 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g19502 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors19503
    expr: rate(node_network_receive_errs_total{group="g19503"}[2m]) + rate(node_network_transmit_errs_total{group="g19503"}[2m]) > 19503
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g19503 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g19503 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate19504
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g19504"}[2m])) / (1024*1024) > 195040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g19504 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g19504 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage19505
    expr: (1 - (node_memory_SwapFree_bytes{group="g19505"} / node_memory_SwapTotal_bytes{group="g19505"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g19505 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g19505 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching19506
    expr: rate(node_context_switches_total{group="g19506"}[5m]) > 19506000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g19506 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g19506 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew19507
    expr: abs(node_timex_offset_seconds{group="g19507"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g19507 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g19507 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills19508
    expr: increase(node_vmstat_oom_kill{group="g19508"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g19508 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g19508 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion19509
    expr: node_filefd_allocated{group="g19509"} / node_filefd_maximum{group="g19509"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g19509 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g19509 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
