groups:
- name: GeneratedGroup178
  rules:
  - alert: HostHighCpuLoad17800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g17800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g17800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g17800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure17801
    expr: node_memory_MemAvailable_bytes{group="g17801"} / node_memory_MemTotal_bytes{group="g17801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g17801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g17801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill17802
    expr: predict_linear(node_filesystem_free_bytes{group="g17802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g17802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g17802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors17803
    expr: rate(node_network_receive_errs_total{group="g17803"}[2m]) + rate(node_network_transmit_errs_total{group="g17803"}[2m]) > 17803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g17803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g17803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate17804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g17804"}[2m])) / (1024*1024) > 178040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g17804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g17804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage17805
    expr: (1 - (node_memory_SwapFree_bytes{group="g17805"} / node_memory_SwapTotal_bytes{group="g17805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g17805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g17805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching17806
    expr: rate(node_context_switches_total{group="g17806"}[5m]) > 17806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g17806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g17806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew17807
    expr: abs(node_timex_offset_seconds{group="g17807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g17807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g17807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills17808
    expr: increase(node_vmstat_oom_kill{group="g17808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g17808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g17808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion17809
    expr: node_filefd_allocated{group="g17809"} / node_filefd_maximum{group="g17809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g17809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g17809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
