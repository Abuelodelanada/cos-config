groups:
- name: GeneratedGroup101
  rules:
  - alert: HostHighCpuLoad10100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g10100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g10100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g10100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure10101
    expr: node_memory_MemAvailable_bytes{group="g10101"} / node_memory_MemTotal_bytes{group="g10101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g10101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g10101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill10102
    expr: predict_linear(node_filesystem_free_bytes{group="g10102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g10102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g10102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors10103
    expr: rate(node_network_receive_errs_total{group="g10103"}[2m]) + rate(node_network_transmit_errs_total{group="g10103"}[2m]) > 10103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g10103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g10103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate10104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g10104"}[2m])) / (1024*1024) > 101040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g10104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g10104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage10105
    expr: (1 - (node_memory_SwapFree_bytes{group="g10105"} / node_memory_SwapTotal_bytes{group="g10105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g10105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g10105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching10106
    expr: rate(node_context_switches_total{group="g10106"}[5m]) > 10106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g10106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g10106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew10107
    expr: abs(node_timex_offset_seconds{group="g10107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g10107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g10107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills10108
    expr: increase(node_vmstat_oom_kill{group="g10108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g10108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g10108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion10109
    expr: node_filefd_allocated{group="g10109"} / node_filefd_maximum{group="g10109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g10109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g10109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
