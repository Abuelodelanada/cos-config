groups:
- name: GeneratedGroup72
  rules:
  - alert: HostHighCpuLoad7200
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g7200"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g7200 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g7200 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure7201
    expr: node_memory_MemAvailable_bytes{group="g7201"} / node_memory_MemTotal_bytes{group="g7201"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g7201 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g7201 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill7202
    expr: predict_linear(node_filesystem_free_bytes{group="g7202"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g7202 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g7202 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors7203
    expr: rate(node_network_receive_errs_total{group="g7203"}[2m]) + rate(node_network_transmit_errs_total{group="g7203"}[2m]) > 7203
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g7203 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g7203 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate7204
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g7204"}[2m])) / (1024*1024) > 72040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g7204 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g7204 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage7205
    expr: (1 - (node_memory_SwapFree_bytes{group="g7205"} / node_memory_SwapTotal_bytes{group="g7205"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g7205 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g7205 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching7206
    expr: rate(node_context_switches_total{group="g7206"}[5m]) > 7206000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g7206 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g7206 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew7207
    expr: abs(node_timex_offset_seconds{group="g7207"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g7207 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g7207 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills7208
    expr: increase(node_vmstat_oom_kill{group="g7208"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g7208 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g7208 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion7209
    expr: node_filefd_allocated{group="g7209"} / node_filefd_maximum{group="g7209"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g7209 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g7209 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
