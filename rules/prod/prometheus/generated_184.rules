groups:
- name: GeneratedGroup184
  rules:
  - alert: HostHighCpuLoad18400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g18400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g18400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g18400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure18401
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g18401"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g18401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g18401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g18401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill18402
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g18402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g18402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g18402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors18403
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g18403"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g18403"}[2m]) > 18403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g18403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g18403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate18404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g18404"}[2m])) / (1024*1024) > 184040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g18404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g18404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage18405
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g18405"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g18405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g18405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g18405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching18406
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g18406"}[5m]) > 18406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g18406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g18406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew18407
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g18407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g18407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g18407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills18408
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g18408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g18408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g18408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion18409
    expr: node_filefd_allocated{%%juju_topology%%,group="g18409"} / node_filefd_maximum{%%juju_topology%%,group="g18409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g18409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g18409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
