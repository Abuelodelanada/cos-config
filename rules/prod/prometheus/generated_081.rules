groups:
- name: GeneratedGroup81
  rules:
  - alert: HostHighCpuLoad8100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g8100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g8100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g8100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure8101
    expr: node_memory_MemAvailable_bytes{group="g8101"} / node_memory_MemTotal_bytes{group="g8101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g8101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g8101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill8102
    expr: predict_linear(node_filesystem_free_bytes{group="g8102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g8102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g8102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors8103
    expr: rate(node_network_receive_errs_total{group="g8103"}[2m]) + rate(node_network_transmit_errs_total{group="g8103"}[2m]) > 8103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g8103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g8103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate8104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g8104"}[2m])) / (1024*1024) > 81040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g8104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g8104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage8105
    expr: (1 - (node_memory_SwapFree_bytes{group="g8105"} / node_memory_SwapTotal_bytes{group="g8105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g8105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g8105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching8106
    expr: rate(node_context_switches_total{group="g8106"}[5m]) > 8106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g8106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g8106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew8107
    expr: abs(node_timex_offset_seconds{group="g8107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g8107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g8107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills8108
    expr: increase(node_vmstat_oom_kill{group="g8108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g8108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g8108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion8109
    expr: node_filefd_allocated{group="g8109"} / node_filefd_maximum{group="g8109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g8109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g8109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
