groups:
- name: GeneratedGroup243
  rules:
  - alert: HostHighCpuLoad24300
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g24300"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g24300 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g24300 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure24301
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g24301"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g24301"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g24301 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g24301 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill24302
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g24302"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g24302 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g24302 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors24303
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g24303"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g24303"}[2m]) > 24303
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g24303 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g24303 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate24304
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g24304"}[2m])) / (1024*1024) > 243040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g24304 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g24304 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage24305
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g24305"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g24305"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g24305 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g24305 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching24306
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g24306"}[5m]) > 24306000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g24306 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g24306 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew24307
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g24307"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g24307 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g24307 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills24308
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g24308"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g24308 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g24308 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion24309
    expr: node_filefd_allocated{%%juju_topology%%,group="g24309"} / node_filefd_maximum{%%juju_topology%%,group="g24309"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g24309 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g24309 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
