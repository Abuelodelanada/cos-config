groups:
- name: GeneratedGroup205
  rules:
  - alert: HostHighCpuLoad20500
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g20500"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g20500 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g20500 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure20501
    expr: node_memory_MemAvailable_bytes{group="g20501"} / node_memory_MemTotal_bytes{group="g20501"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g20501 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g20501 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill20502
    expr: predict_linear(node_filesystem_free_bytes{group="g20502"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g20502 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g20502 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors20503
    expr: rate(node_network_receive_errs_total{group="g20503"}[2m]) + rate(node_network_transmit_errs_total{group="g20503"}[2m]) > 20503
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g20503 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g20503 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate20504
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g20504"}[2m])) / (1024*1024) > 205040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g20504 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g20504 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage20505
    expr: (1 - (node_memory_SwapFree_bytes{group="g20505"} / node_memory_SwapTotal_bytes{group="g20505"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g20505 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g20505 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching20506
    expr: rate(node_context_switches_total{group="g20506"}[5m]) > 20506000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g20506 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g20506 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew20507
    expr: abs(node_timex_offset_seconds{group="g20507"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g20507 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g20507 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills20508
    expr: increase(node_vmstat_oom_kill{group="g20508"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g20508 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g20508 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion20509
    expr: node_filefd_allocated{group="g20509"} / node_filefd_maximum{group="g20509"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g20509 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g20509 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
