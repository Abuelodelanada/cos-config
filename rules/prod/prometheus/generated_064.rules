groups:
- name: GeneratedGroup64
  rules:
  - alert: HostHighCpuLoad6400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g6400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g6400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g6400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure6401
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g6401"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g6401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g6401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g6401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill6402
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g6402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g6402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g6402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors6403
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g6403"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g6403"}[2m]) > 6403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g6403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g6403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate6404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g6404"}[2m])) / (1024*1024) > 64040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g6404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g6404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage6405
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g6405"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g6405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g6405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g6405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching6406
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g6406"}[5m]) > 6406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g6406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g6406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew6407
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g6407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g6407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g6407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills6408
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g6408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g6408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g6408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion6409
    expr: node_filefd_allocated{%%juju_topology%%,group="g6409"} / node_filefd_maximum{%%juju_topology%%,group="g6409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g6409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g6409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
