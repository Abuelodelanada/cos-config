groups:
- name: GeneratedGroup19
  rules:
  - alert: HostHighCpuLoad1900
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g1900"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g1900 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g1900 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure1901
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g1901"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g1901"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g1901 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g1901 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill1902
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g1902"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g1902 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g1902 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors1903
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g1903"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g1903"}[2m]) > 1903
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g1903 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g1903 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate1904
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g1904"}[2m])) / (1024*1024) > 19040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g1904 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g1904 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage1905
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g1905"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g1905"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g1905 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g1905 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching1906
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g1906"}[5m]) > 1906000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g1906 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g1906 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew1907
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g1907"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g1907 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g1907 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills1908
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g1908"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g1908 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g1908 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion1909
    expr: node_filefd_allocated{%%juju_topology%%,group="g1909"} / node_filefd_maximum{%%juju_topology%%,group="g1909"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g1909 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g1909 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
