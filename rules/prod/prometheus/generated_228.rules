groups:
- name: GeneratedGroup228
  rules:
  - alert: HostHighCpuLoad22800
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g22800"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g22800 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g22800 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure22801
    expr: node_memory_MemAvailable_bytes{group="g22801"} / node_memory_MemTotal_bytes{group="g22801"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g22801 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g22801 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill22802
    expr: predict_linear(node_filesystem_free_bytes{group="g22802"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g22802 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g22802 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors22803
    expr: rate(node_network_receive_errs_total{group="g22803"}[2m]) + rate(node_network_transmit_errs_total{group="g22803"}[2m]) > 22803
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g22803 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g22803 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate22804
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g22804"}[2m])) / (1024*1024) > 228040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g22804 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g22804 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage22805
    expr: (1 - (node_memory_SwapFree_bytes{group="g22805"} / node_memory_SwapTotal_bytes{group="g22805"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g22805 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g22805 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching22806
    expr: rate(node_context_switches_total{group="g22806"}[5m]) > 22806000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g22806 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g22806 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew22807
    expr: abs(node_timex_offset_seconds{group="g22807"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g22807 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g22807 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills22808
    expr: increase(node_vmstat_oom_kill{group="g22808"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g22808 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g22808 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion22809
    expr: node_filefd_allocated{group="g22809"} / node_filefd_maximum{group="g22809"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g22809 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g22809 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
