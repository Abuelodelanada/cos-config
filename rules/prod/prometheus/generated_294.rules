groups:
- name: GeneratedGroup294
  rules:
  - alert: HostHighCpuLoad29400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g29400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g29400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g29400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure29401
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g29401"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g29401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g29401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g29401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill29402
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g29402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g29402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g29402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors29403
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g29403"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g29403"}[2m]) > 29403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g29403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g29403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate29404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g29404"}[2m])) / (1024*1024) > 294040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g29404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g29404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage29405
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g29405"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g29405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g29405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g29405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching29406
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g29406"}[5m]) > 29406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g29406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g29406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew29407
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g29407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g29407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g29407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills29408
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g29408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g29408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g29408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion29409
    expr: node_filefd_allocated{%%juju_topology%%,group="g29409"} / node_filefd_maximum{%%juju_topology%%,group="g29409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g29409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g29409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
