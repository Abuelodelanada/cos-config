groups:
- name: GeneratedGroup256
  rules:
  - alert: HostHighCpuLoad25600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g25600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g25600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g25600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure25601
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g25601"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g25601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g25601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g25601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill25602
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g25602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g25602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g25602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors25603
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g25603"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g25603"}[2m]) > 25603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g25603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g25603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate25604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g25604"}[2m])) / (1024*1024) > 256040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g25604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g25604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage25605
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g25605"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g25605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g25605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g25605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching25606
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g25606"}[5m]) > 25606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g25606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g25606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew25607
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g25607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g25607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g25607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills25608
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g25608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g25608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g25608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion25609
    expr: node_filefd_allocated{%%juju_topology%%,group="g25609"} / node_filefd_maximum{%%juju_topology%%,group="g25609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g25609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g25609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
