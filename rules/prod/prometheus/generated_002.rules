groups:
- name: GeneratedGroup2
  rules:
  - alert: HostHighCpuLoad200
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g200"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g200 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g200 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure201
    expr: node_memory_MemAvailable_bytes{group="g201"} / node_memory_MemTotal_bytes{group="g201"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g201 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g201 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill202
    expr: predict_linear(node_filesystem_free_bytes{group="g202"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g202 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g202 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors203
    expr: rate(node_network_receive_errs_total{group="g203"}[2m]) + rate(node_network_transmit_errs_total{group="g203"}[2m]) > 203
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g203 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g203 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate204
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g204"}[2m])) / (1024*1024) > 2040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g204 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g204 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage205
    expr: (1 - (node_memory_SwapFree_bytes{group="g205"} / node_memory_SwapTotal_bytes{group="g205"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g205 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g205 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching206
    expr: rate(node_context_switches_total{group="g206"}[5m]) > 206000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g206 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g206 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew207
    expr: abs(node_timex_offset_seconds{group="g207"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g207 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g207 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills208
    expr: increase(node_vmstat_oom_kill{group="g208"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g208 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g208 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion209
    expr: node_filefd_allocated{group="g209"} / node_filefd_maximum{group="g209"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g209 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g209 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
