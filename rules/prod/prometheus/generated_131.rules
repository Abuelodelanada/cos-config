groups:
- name: GeneratedGroup131
  rules:
  - alert: HostHighCpuLoad13100
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g13100"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g13100 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g13100 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure13101
    expr: node_memory_MemAvailable_bytes{group="g13101"} / node_memory_MemTotal_bytes{group="g13101"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g13101 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g13101 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill13102
    expr: predict_linear(node_filesystem_free_bytes{group="g13102"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g13102 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g13102 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors13103
    expr: rate(node_network_receive_errs_total{group="g13103"}[2m]) + rate(node_network_transmit_errs_total{group="g13103"}[2m]) > 13103
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g13103 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g13103 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate13104
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g13104"}[2m])) / (1024*1024) > 131040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g13104 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g13104 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage13105
    expr: (1 - (node_memory_SwapFree_bytes{group="g13105"} / node_memory_SwapTotal_bytes{group="g13105"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g13105 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g13105 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching13106
    expr: rate(node_context_switches_total{group="g13106"}[5m]) > 13106000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g13106 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g13106 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew13107
    expr: abs(node_timex_offset_seconds{group="g13107"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g13107 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g13107 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills13108
    expr: increase(node_vmstat_oom_kill{group="g13108"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g13108 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g13108 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion13109
    expr: node_filefd_allocated{group="g13109"} / node_filefd_maximum{group="g13109"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g13109 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g13109 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
