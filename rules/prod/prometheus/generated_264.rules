groups:
- name: GeneratedGroup264
  rules:
  - alert: HostHighCpuLoad26400
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g26400"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g26400 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g26400 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure26401
    expr: node_memory_MemAvailable_bytes{group="g26401"} / node_memory_MemTotal_bytes{group="g26401"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g26401 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g26401 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill26402
    expr: predict_linear(node_filesystem_free_bytes{group="g26402"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g26402 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g26402 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors26403
    expr: rate(node_network_receive_errs_total{group="g26403"}[2m]) + rate(node_network_transmit_errs_total{group="g26403"}[2m]) > 26403
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g26403 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g26403 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate26404
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g26404"}[2m])) / (1024*1024) > 264040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g26404 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g26404 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage26405
    expr: (1 - (node_memory_SwapFree_bytes{group="g26405"} / node_memory_SwapTotal_bytes{group="g26405"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g26405 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g26405 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching26406
    expr: rate(node_context_switches_total{group="g26406"}[5m]) > 26406000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g26406 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g26406 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew26407
    expr: abs(node_timex_offset_seconds{group="g26407"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g26407 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g26407 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills26408
    expr: increase(node_vmstat_oom_kill{group="g26408"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g26408 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g26408 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion26409
    expr: node_filefd_allocated{group="g26409"} / node_filefd_maximum{group="g26409"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g26409 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g26409 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
