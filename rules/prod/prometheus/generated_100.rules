groups:
- name: GeneratedGroup100
  rules:
  - alert: HostHighCpuLoad10000
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g10000"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g10000 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g10000 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure10001
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g10001"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g10001"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g10001 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g10001 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill10002
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g10002"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g10002 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g10002 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors10003
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g10003"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g10003"}[2m]) > 10003
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g10003 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g10003 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate10004
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g10004"}[2m])) / (1024*1024) > 100040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g10004 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g10004 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage10005
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g10005"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g10005"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g10005 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g10005 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching10006
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g10006"}[5m]) > 10006000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g10006 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g10006 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew10007
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g10007"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g10007 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g10007 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills10008
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g10008"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g10008 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g10008 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion10009
    expr: node_filefd_allocated{%%juju_topology%%,group="g10009"} / node_filefd_maximum{%%juju_topology%%,group="g10009"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g10009 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g10009 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
