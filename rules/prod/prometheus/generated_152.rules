groups:
- name: GeneratedGroup152
  rules:
  - alert: HostHighCpuLoad15200
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g15200"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g15200 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g15200 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure15201
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g15201"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g15201"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g15201 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g15201 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill15202
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g15202"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g15202 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g15202 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors15203
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g15203"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g15203"}[2m]) > 15203
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g15203 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g15203 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate15204
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g15204"}[2m])) / (1024*1024) > 152040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g15204 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g15204 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage15205
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g15205"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g15205"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g15205 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g15205 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching15206
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g15206"}[5m]) > 15206000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g15206 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g15206 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew15207
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g15207"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g15207 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g15207 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills15208
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g15208"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g15208 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g15208 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion15209
    expr: node_filefd_allocated{%%juju_topology%%,group="g15209"} / node_filefd_maximum{%%juju_topology%%,group="g15209"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g15209 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g15209 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
