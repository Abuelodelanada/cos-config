groups:
- name: GeneratedGroup170
  rules:
  - alert: HostHighCpuLoad17000
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{%%juju_topology%%,mode!="idle",group="g17000"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g17000 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g17000 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure17001
    expr: node_memory_MemAvailable_bytes{%%juju_topology%%,group="g17001"} / node_memory_MemTotal_bytes{%%juju_topology%%,group="g17001"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g17001 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g17001 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill17002
    expr: predict_linear(node_filesystem_free_bytes{%%juju_topology%%,group="g17002"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g17002 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g17002 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors17003
    expr: rate(node_network_receive_errs_total{%%juju_topology%%,group="g17003"}[2m]) + rate(node_network_transmit_errs_total{%%juju_topology%%,group="g17003"}[2m]) > 17003
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g17003 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g17003 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate17004
    expr: sum by (instance) (rate(node_disk_read_bytes_total{%%juju_topology%%,group="g17004"}[2m])) / (1024*1024) > 170040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g17004 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g17004 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage17005
    expr: (1 - (node_memory_SwapFree_bytes{%%juju_topology%%,group="g17005"} / node_memory_SwapTotal_bytes{%%juju_topology%%,group="g17005"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g17005 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g17005 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching17006
    expr: rate(node_context_switches_total{%%juju_topology%%,group="g17006"}[5m]) > 17006000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g17006 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g17006 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew17007
    expr: abs(node_timex_offset_seconds{%%juju_topology%%,group="g17007"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g17007 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g17007 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills17008
    expr: increase(node_vmstat_oom_kill{%%juju_topology%%,group="g17008"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g17008 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g17008 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion17009
    expr: node_filefd_allocated{%%juju_topology%%,group="g17009"} / node_filefd_maximum{%%juju_topology%%,group="g17009"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g17009 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g17009 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
