groups:
- name: GeneratedGroup26
  rules:
  - alert: HostHighCpuLoad2600
    expr: (sum by (instance) (avg by (mode, instance) (rate(node_cpu_seconds_total{mode!="idle",group="g2600"}[2m]))) * 100) > 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host CPU load is high on group g2600 (instance {{ $labels.instance }})
      description: >-
        Host CPU load is high on group g2600 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostMemoryPressure2601
    expr: node_memory_MemAvailable_bytes{group="g2601"} / node_memory_MemTotal_bytes{group="g2601"} * 100 < 10
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host memory available is low on group g2601 (instance {{ $labels.instance }})
      description: >-
        Host memory available is low on group g2601 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostDiskWillFill2602
    expr: predict_linear(node_filesystem_free_bytes{group="g2602"}[6h], 24*3600) < 0
    for: 1h
    labels:
      severity: warning
    annotations:
      summary: Host disk on group g2602 will fill in 24h (instance {{ $labels.instance }})
      description: >-
        Host disk on group g2602 will fill in 24h (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostNetworkErrors2603
    expr: rate(node_network_receive_errs_total{group="g2603"}[2m]) + rate(node_network_transmit_errs_total{group="g2603"}[2m]) > 2603
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host network errors on group g2603 (instance {{ $labels.instance }})
      description: >-
        Host network errors on group g2603 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostUnusualDiskReadRate2604
    expr: sum by (instance) (rate(node_disk_read_bytes_total{group="g2604"}[2m])) / (1024*1024) > 26040
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host unusual disk read rate on group g2604 (instance {{ $labels.instance }})
      description: >-
        Host unusual disk read rate on group g2604 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostSwapUsage2605
    expr: (1 - (node_memory_SwapFree_bytes{group="g2605"} / node_memory_SwapTotal_bytes{group="g2605"})) * 100 > 50
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host swap usage is high on group g2605 (instance {{ $labels.instance }})
      description: >-
        Host swap usage is high on group g2605 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostContextSwitching2606
    expr: rate(node_context_switches_total{group="g2606"}[5m]) > 2606000
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: Host context switching is high on group g2606 (instance {{ $labels.instance }})
      description: >-
        Host context switching is high on group g2606 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostClockSkew2607
    expr: abs(node_timex_offset_seconds{group="g2607"}) > 0.05
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Host clock skew detected on group g2607 (instance {{ $labels.instance }})
      description: >-
        Host clock skew detected on group g2607 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostOOMKills2608
    expr: increase(node_vmstat_oom_kill{group="g2608"}[5m]) > 0
    for: 0m
    labels:
      severity: critical
    annotations:
      summary: Host OOM kill detected on group g2608 (instance {{ $labels.instance }})
      description: >-
        Host OOM kill detected on group g2608 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
  - alert: HostFiledescriptorsExhaustion2609
    expr: node_filefd_allocated{group="g2609"} / node_filefd_maximum{group="g2609"} * 100 > 90
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Host file descriptors near exhaustion on group g2609 (instance {{ $labels.instance }})
      description: >-
        Host file descriptors near exhaustion on group g2609 (instance {{ $labels.instance }}).
          VALUE = {{ $value }}
          LABELS = {{ $labels }}
